<?xml version="1.0" encoding="utf-8"?>
<!--
    Text editing mode overlay layout - replaces keyboard with a Gboard-style rich text editing panel
    SPDX-License-Identifier: GPL-3.0-only
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Row 1: Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">
        
        <TextView
            android:id="@+id/btn_select_all"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:layout_margin="3dp"
            android:text="Select All"
            android:gravity="center"
            android:textAlignment="center"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_select"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:text="Select"
            android:gravity="center"
            android:textAlignment="center"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_cut"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:text="Cut"
            android:gravity="center"
            android:textAlignment="center"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_copy"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:text="Copy"
            android:gravity="center"
            android:textAlignment="center"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_paste"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:text="Paste"
            android:gravity="center"
            android:textAlignment="center"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:padding="12dp"
            android:contentDescription="Close text editing mode"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Row 2: Nav and word movements -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:id="@+id/btn_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:padding="12dp"
            android:contentDescription="Move to start of line"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_word_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:padding="12dp"
            android:contentDescription="Move cursor word left"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_arrow_up"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:padding="12dp"
            android:contentDescription="Move cursor up"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_word_right"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:padding="12dp"
            android:contentDescription="Move cursor word right"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_end"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:padding="12dp"
            android:contentDescription="Move to end of line"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Row 3: Delete and horizontal nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:id="@+id/btn_backspace"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:padding="12dp"
            android:contentDescription="Backspace"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_arrow_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:padding="12dp"
            android:contentDescription="Move cursor left"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_arrow_down"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:padding="12dp"
            android:contentDescription="Move cursor down"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_arrow_right"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:padding="12dp"
            android:contentDescription="Move cursor right"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:padding="12dp"
            android:contentDescription="Forward delete"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
